# ─────────────────────────────────────────────
# Jira Cloud Configuration
# ─────────────────────────────────────────────
# Base URL of your Jira Cloud instance (no trailing slash)
JIRA_BASE_URL=https://your-org.atlassian.net

# Jira account email address
JIRA_EMAIL=you@yourcompany.com

# Jira API token — generate at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your_jira_api_token_here

# ─────────────────────────────────────────────
# Salesforce Configuration
# ─────────────────────────────────────────────
# Salesforce login URL (use https://test.salesforce.com for sandbox)
SF_LOGIN_URL=https://login.salesforce.com

# Connected App Client ID (Consumer Key)
SF_CLIENT_ID=your_connected_app_client_id

# Connected App Client Secret (Consumer Secret)
SF_CLIENT_SECRET=your_connected_app_client_secret

# Salesforce username
SF_USERNAME=you@yourorg.com

# Salesforce password
SF_PASSWORD=yourpassword

# Salesforce security token (appended to password in OAuth flow)
# Reset at: Setup → My Personal Information → Reset My Security Token
SF_SECURITY_TOKEN=yourSecurityToken

# Salesforce API version (default: v61.0)
SF_API_VERSION=v61.0

# ─────────────────────────────────────────────
# n8n Configuration
# ─────────────────────────────────────────────
# Base URL of your n8n instance
N8N_BASE_URL=https://your-n8n-instance.com

# n8n API key — generate at: n8n Settings → API → Create API Key
N8N_API_KEY=your_n8n_api_key_here

# ─────────────────────────────────────────────
# MCP Server Configuration (SSE mode only)
# ─────────────────────────────────────────────
# Port for the SSE HTTP server (default: 3000)
MCP_PORT=3000

# Log level: debug | info | warn | error (default: info)
LOG_LEVEL=info
